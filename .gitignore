*.log
logs/
*.txt.log

# Temporary files
tmp/
temp/
.tmp/

# Environment files
.env
.env.local
.env.*.local

# API Keys and secrets (should never be committed)
secrets.plist
config.plist
api-keys.txt
*.p12
*.mobileprovision

# Documentation build
docs/_build/
docs/site/

# StreamKit specific
#
